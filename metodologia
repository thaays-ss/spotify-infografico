<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Metodologia — A Corrida pelo Algoritmo</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --preto:   #0e0e0e;
  --verde:   #1DB954;
  --verde2:  #17a349;
  --branco:  #f5f5f0;
  --cinza:   #888;
  --cinza2:  #555;
  --lilas:   #9B59B6;
  --laranja: #E67E22;
  --azul:    #3498DB;
  --card:    #1a1a1a;
  --linha:   #2a2a2a;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background: var(--preto);
  color: var(--branco);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  line-height: 1.7;
  overflow-x: hidden;
}
#progress {
  position:fixed; top:0; left:0; height:3px;
  background:var(--verde); z-index:999; width:0%;
  transition: width 0.1s;
}

/* NAV */
nav {
  position: fixed; top:3px; left:0; right:0;
  background: rgba(14,14,14,0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--linha);
  padding: 0.7rem 2rem;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 100;
}
.nav-brand {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 0.12em;
  color: var(--verde);
}
.nav-links {
  display: flex; gap: 2rem;
  list-style: none;
}
.nav-links a {
  font-size: 0.75rem;
  color: var(--cinza);
  text-decoration: none;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 500;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--verde); }
.nav-back {
  font-size: 0.75rem;
  color: var(--cinza2);
  text-decoration: none;
  letter-spacing: 0.1em;
}
.nav-back:hover { color: var(--verde); }

/* HERO */
.hero {
  min-height: 60vh;
  display: flex; flex-direction:column;
  justify-content:center; align-items:center;
  text-align:center;
  padding: 8rem 2rem 4rem;
  position:relative; overflow:hidden;
}
.hero::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse at 30% 50%, rgba(29,185,84,0.06) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 50%, rgba(155,89,182,0.04) 0%, transparent 60%);
}
.hero-eyebrow {
  font-size:0.72rem; letter-spacing:0.28em;
  color:var(--verde); text-transform:uppercase;
  font-weight:500; margin-bottom:1.5rem;
}
.hero-title {
  font-family:'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 8vw, 6rem);
  line-height:0.95;
  margin-bottom:1rem;
}
.hero-title span { color:var(--verde); }
.hero-sub {
  font-family:'DM Serif Display', serif;
  font-size:clamp(1rem,2vw,1.3rem);
  color:var(--cinza); font-style:italic;
  max-width:560px; margin-bottom:2.5rem;
}
.hero-line {
  width:60px; height:3px;
  background:var(--verde); margin:0 auto;
}

/* SECTION WRAPPER */
.wrap { max-width:900px; margin:0 auto; padding:5rem 2rem; }
.wrap.wide { max-width:1100px; }
.divider { width:100%; height:1px; background:var(--linha); }

/* CHAPTER */
.chap {
  display:flex; align-items:center; gap:0.75rem;
  margin-bottom:1.2rem;
}
.chap-n {
  font-family:'Bebas Neue', sans-serif;
  font-size:0.85rem; color:var(--verde);
  background:rgba(29,185,84,0.1);
  border:1px solid rgba(29,185,84,0.2);
  padding:0.15rem 0.55rem; letter-spacing:0.1em;
}
.chap-l {
  font-size:0.7rem; letter-spacing:0.2em;
  text-transform:uppercase; color:var(--cinza);
  font-weight:500;
}

/* DISPLAY HEADING */
.display {
  font-family:'Bebas Neue', sans-serif;
  font-size:clamp(2.2rem,5vw,4rem);
  line-height:1; margin-bottom:1.2rem;
}
.display span { color:var(--verde); }
.display .alt  { color:var(--lilas); }
.display .warn { color:var(--laranja); }

/* BODY */
.lead {
  font-size:1.05rem; color:#ccc;
  line-height:1.8; margin-bottom:1.2rem;
}
.lead strong { color:var(--branco); font-weight:500; }
.lead em { color:var(--verde); font-style:normal; font-weight:500; }

/* PIPELINE STEPS */
.pipeline {
  display:grid;
  grid-template-columns: repeat(5, 1fr);
  gap:0;
  margin:3rem 0;
  position:relative;
}
.pipeline::before {
  content:'';
  position:absolute;
  top:2.8rem; left:5%; right:5%;
  height:2px;
  background:linear-gradient(to right, var(--verde), var(--lilas), var(--laranja), #3498DB, var(--verde));
  z-index:0;
}
.step {
  background:var(--card);
  border:1px solid var(--linha);
  padding:1.5rem 1rem 1.2rem;
  position:relative; z-index:1;
  transition:transform 0.2s;
  text-align:center;
}
.step:hover { transform:translateY(-4px); }
.step:first-child { border-radius:8px 0 0 8px; }
.step:last-child  { border-radius:0 8px 8px 0; }
.step-badge {
  width:2.2rem; height:2.2rem; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:'Bebas Neue', sans-serif;
  font-size:1rem; margin:0 auto 1rem;
  position:relative;
}
.step-num {
  font-family:'Bebas Neue', sans-serif;
  font-size:0.7rem; color:var(--preto);
  font-weight:900;
}
.step-title {
  font-size:0.95rem; font-weight:500;
  color:var(--branco); margin-bottom:0.8rem;
}
.step-items {
  list-style:none;
}
.step-items li {
  font-size:0.78rem; color:var(--cinza);
  padding:0.18rem 0;
  border-top:1px solid var(--linha);
}
.step-items li:first-child { border-top:none; }
.step-accent {
  position:absolute; top:0; left:0; right:0;
  height:3px; border-radius:3px 3px 0 0;
}

/* SCREENSHOT CARDS */
.screen-wrap {
  background:var(--card);
  border:1px solid var(--linha);
  border-radius:8px;
  overflow:hidden;
  margin:2rem 0;
  position:relative;
}
.screen-bar {
  background:#1e1e1e;
  padding:0.6rem 1rem;
  display:flex; align-items:center; gap:0.5rem;
  border-bottom:1px solid var(--linha);
}
.screen-dot {
  width:10px; height:10px; border-radius:50%;
}
.screen-title {
  font-size:0.75rem; color:var(--cinza);
  margin-left:0.5rem; font-weight:500;
  letter-spacing:0.05em;
}
.screen-url {
  margin-left:auto;
  font-size:0.68rem; color:var(--cinza2);
  font-family:monospace;
}
.screen-img {
  width:100%; display:block;
  border-bottom:3px solid var(--verde);
}
.screen-caption {
  padding:1rem 1.2rem;
  font-size:0.82rem; color:var(--cinza);
  line-height:1.6;
}
.screen-caption strong { color:var(--verde); font-weight:500; }

/* CHALLENGE CARDS */
.challenge-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:1px; background:var(--linha);
  margin:2rem 0;
}
.challenge {
  background:var(--card);
  padding:1.5rem;
  position:relative;
}
.challenge::before {
  content:'';
  position:absolute; top:0; left:0;
  width:3px; height:100%;
}
.challenge.c1::before { background:var(--laranja); }
.challenge.c2::before { background:var(--lilas); }
.challenge.c3::before { background:var(--verde); }
.challenge.c4::before { background:var(--azul); }
.challenge-tag {
  font-size:0.65rem; letter-spacing:0.2em;
  text-transform:uppercase; font-weight:500;
  margin-bottom:0.5rem;
}
.c1 .challenge-tag { color:var(--laranja); }
.c2 .challenge-tag { color:var(--lilas); }
.c3 .challenge-tag { color:var(--verde); }
.c4 .challenge-tag { color:var(--azul); }
.challenge h3 {
  font-size:1rem; font-weight:500;
  color:var(--branco); margin-bottom:0.5rem;
  line-height:1.3;
}
.challenge p {
  font-size:0.85rem; color:var(--cinza); line-height:1.6;
}
.challenge .sol {
  margin-top:0.5rem;
  font-size:0.82rem; color:var(--branco);
  padding:0.4rem 0.7rem;
  background:rgba(255,255,255,0.04);
  border-left:2px solid currentColor;
}
.c1 .sol { color:var(--laranja); }
.c2 .sol { color:var(--lilas); }
.c3 .sol { color:var(--verde); }
.c4 .sol { color:var(--azul); }

/* CODE BLOCK */
.code-block {
  background:#111;
  border:1px solid var(--linha);
  border-left:3px solid var(--verde);
  padding:1.2rem 1.5rem;
  font-family:monospace;
  font-size:0.82rem;
  line-height:1.7;
  color:#a8ff78;
  margin:1.5rem 0;
  overflow-x:auto;
}
.code-block .comment { color:#555; }
.code-block .keyword { color:var(--lilas); }
.code-block .string  { color:#f9ca24; }
.code-block .func    { color:#1DB954; }

/* BQ TABLE */
.bq-table {
  width:100%; border-collapse:collapse;
  margin:2rem 0; font-size:0.85rem;
}
.bq-table th {
  background:#1e1e1e; color:var(--verde);
  padding:0.6rem 1rem; text-align:left;
  font-size:0.72rem; letter-spacing:0.1em;
  text-transform:uppercase; font-weight:500;
  border-bottom:2px solid var(--verde);
}
.bq-table td {
  padding:0.55rem 1rem; color:var(--cinza);
  border-bottom:1px solid var(--linha);
}
.bq-table tr:hover td { background:#1a1a1a; }
.bq-table .tname { color:var(--branco); font-weight:500; font-family:monospace; }
.bq-table .tcount { color:var(--verde); font-weight:500; }

/* STACK PILLS */
.stack { display:flex; flex-wrap:wrap; gap:0.6rem; margin:1.5rem 0; }
.pill {
  display:flex; align-items:center; gap:0.5rem;
  background:var(--card); border:1px solid var(--linha);
  padding:0.4rem 0.9rem; border-radius:2px;
  font-size:0.8rem; color:var(--cinza);
  font-weight:500;
}
.pill-dot {
  width:6px; height:6px; border-radius:50%;
}

/* PULL QUOTE */
.pullquote {
  font-family:'DM Serif Display', serif;
  font-size:clamp(1.2rem,2.5vw,1.6rem);
  color:var(--branco); font-style:italic;
  border-left:3px solid var(--verde);
  padding:1.2rem 0 1.2rem 1.8rem;
  margin:2.5rem 0; line-height:1.45;
}

/* FOOTER */
footer {
  text-align:center; padding:4rem 2rem 3rem;
  border-top:1px solid var(--linha);
  font-size:0.72rem; color:#444; line-height:1.9;
}
footer strong { color:var(--cinza); font-weight:500; }

/* ANIM */
@keyframes bounce { 0%,100% { transform:translateY(0); } 50% { transform:translateY(6px); } }
.bounce { animation:bounce 2s infinite; }

@media(max-width:700px){
  .pipeline { grid-template-columns:1fr; }
  .pipeline::before { display:none; }
  .step:first-child,.step:last-child { border-radius:8px; }
  .challenge-grid { grid-template-columns:1fr; }
  .nav-links { display:none; }
}
</style>
</head>
