        <li>Google Colab</li>
        <li>Client Credentials</li>
      </ul>
    </div>
    <div class="step">
      <div class="step-accent" style="background:var(--laranja)"></div>
      <div class="step-badge" style="background:var(--laranja)">
        <span class="step-num">03</span>
      </div>
      <div class="step-title">BigQuery</div>
      <ul class="step-items">
        <li>GCP · spotify_mba</li>
        <li>4 tabelas SQL</li>
        <li>Views analíticas</li>
      </ul>
    </div>
    <div class="step">
      <div class="step-accent" style="background:#3498DB"></div>
      <div class="step-badge" style="background:#3498DB">
